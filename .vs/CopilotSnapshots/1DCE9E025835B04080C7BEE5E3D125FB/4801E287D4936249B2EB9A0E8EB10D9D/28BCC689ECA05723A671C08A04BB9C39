        // If we detect ORA-12505, try to replace SID= with SERVICE_NAME= and retry.
        private static string GetAlternateConnIfNeeded(string conn)
        {
            if (string.IsNullOrEmpty(conn)) return conn;
            try
            {
                if (conn.IndexOf("SID=", StringComparison.OrdinalIgnoreCase) >= 0 && conn.IndexOf("SERVICE_NAME=", StringComparison.OrdinalIgnoreCase) < 0)
                {
                    return conn.Replace("SID=", "SERVICE_NAME=");
                }

                // If caller used SERVICE_NAME but listener expects SID, try the reverse
                if (conn.IndexOf("SERVICE_NAME=", StringComparison.OrdinalIgnoreCase) >= 0 && conn.IndexOf("SID=", StringComparison.OrdinalIgnoreCase) < 0)
                {
                    return conn.Replace("SERVICE_NAME=", "SID=");
                }

                // Fallback: if connection uses a full DESCRIPTION, try to use EZCONNECT (host:port/service)
                // Attempt to parse HOST, PORT and SERVICE_NAME/SID to build an EZCONNECT string
                var lower = conn.ToLowerInvariant();
                if (lower.Contains("host=") && lower.Contains("port=") && (lower.Contains("sid=") || lower.Contains("service_name=")))
                {
                    try
                    {
                        // crude parse
                        string host = null, port = null, svc = null;
                        var parts = conn.Split(new[] { '(', ')', '=' }, StringSplitOptions.RemoveEmptyEntries);
                        for (int i = 0; i < parts.Length - 1; i++)
                        {
                            var p = parts[i].Trim().ToLowerInvariant();
                            if (p == "host") host = parts[i + 1].Trim();
                            if (p == "port") port = parts[i + 1].Trim();
                            if (p == "sid" || p == "service_name") svc = parts[i + 1].Trim();
                        }

                        if (!string.IsNullOrEmpty(host) && !string.IsNullOrEmpty(port) && !string.IsNullOrEmpty(svc))
                        {
                            // construct EZCONNECT and keep user/password from original conn if present
                            var user = ExtractConnPart(conn, "User Id", "UserId", "UID", "User");
                            var pwd = ExtractConnPart(conn, "Password", "PWD");
                            var ez = $"User Id={user};Password={pwd};Data Source={host}:{port}/{svc};Connection Timeout=60;Pooling=false";
                            return ez;
                        }
                    }
                    catch { }
                }
            }
            catch { }
            return conn;
        }

        private static string ExtractConnPart(string conn, params string[] keys)
        {
            foreach (var key in keys)
            {
                var idx = conn.IndexOf(key + "=", StringComparison.OrdinalIgnoreCase);
                if (idx >= 0)
                {
                    var substr = conn.Substring(idx + key.Length + 1);
                    var end = substr.IndexOf(';');
                    var val = end >= 0 ? substr.Substring(0, end) : substr;
                    return val.Trim();
                }
            }
            return string.Empty;
        }

        #region Users
        public static List<User> LoadUsers()
        {
            EnsureOracleConfigured();
            try
            {
                LogDebug("LoadUsers: using Oracle");
                EnsureOracleTables();
