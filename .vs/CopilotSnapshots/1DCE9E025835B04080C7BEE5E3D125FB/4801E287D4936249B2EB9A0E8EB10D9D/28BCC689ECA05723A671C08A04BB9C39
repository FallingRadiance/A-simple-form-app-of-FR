        #region Oracle helpers (use Oracle.ManagedDataAccess.Client)
        private static void EnsureOracleTables()
        {
            EnsureOracleConfigured();

            var checkUsers = "SELECT COUNT(*) FROM USER_TABLES WHERE TABLE_NAME = 'USERS'";
            var checkDrinks = "SELECT COUNT(*) FROM USER_TABLES WHERE TABLE_NAME = 'DRINKS'";
            var checkOrders = "SELECT COUNT(*) FROM USER_TABLES WHERE TABLE_NAME = 'ORDERS'";
            var checkItems = "SELECT COUNT(*) FROM USER_TABLES WHERE TABLE_NAME = 'ORDER_ITEMS'";

            var r1 = ExecuteScalar(checkUsers);
            if (r1 == "0")
            {
                ExecuteNonQuery(@"
                    CREATE TABLE USERS (
                        PHONE VARCHAR2(11) PRIMARY KEY,
                        USERNAME VARCHAR2(100),
                        PASSWORD VARCHAR2(200),
                        EMAIL VARCHAR2(200),
                        ADDRESS VARCHAR2(200),
                        CONSTRAINT chk_phone CHECK (REGEXP_LIKE(PHONE, '^[0-9]{11}$'))
                    )");
            }
            var r2 = ExecuteScalar(checkDrinks);
            if (r2 == "0")
            {
                ExecuteNonQuery(@"
                    CREATE TABLE DRINKS (
                        ID VARCHAR2(50) PRIMARY KEY,
                        NAME VARCHAR2(200),
                        CATEGORY VARCHAR2(100),
                        PRICE NUMBER(12,2) CHECK (PRICE > 0),
                        STOCK NUMBER CHECK (STOCK >= 0)
                    )");
            }
            var r3 = ExecuteScalar(checkOrders);
            if (r3 == "0")
            {
                ExecuteNonQuery(@"
                    CREATE TABLE ORDERS (
                        ID VARCHAR2(100) PRIMARY KEY,
                        USERNAME VARCHAR2(100),
                        PHONE VARCHAR2(11),
                        CREATEDAT TIMESTAMP,
                        TOTAL NUMBER(12,2) CHECK (TOTAL >= 0),
                        CONSTRAINT fk_order_user FOREIGN KEY (PHONE) REFERENCES USERS(PHONE)
                    )");
            }
            var r4 = ExecuteScalar(checkItems);
            if (r4 == "0")
            {
                ExecuteNonQuery(@"
                    CREATE TABLE ORDER_ITEMS (
                        ORDERID VARCHAR2(100),
                        DRINKID VARCHAR2(50),
                        DRINKNAME VARCHAR2(200),
                        UNITPRICE NUMBER(12,2),
                        QUANTITY NUMBER,
                        PRIMARY KEY (ORDERID, DRINKID),
                        CONSTRAINT fk_item_order FOREIGN KEY (ORDERID) REFERENCES ORDERS(ID),
                        CONSTRAINT fk_item_drink FOREIGN KEY (DRINKID) REFERENCES DRINKS(ID),
                        CONSTRAINT chk_quantity CHECK (QUANTITY >= 1)
                    )");
            }
        }

        private static string ExecuteScalar(string sql, params (string, object)[] parms)
        {
            try
            {
                using (var con = new OracleConnection(OracleConn))
                {
                    con.Open();
                    using (var cmd = new OracleCommand(sql, con))
                    {
                        cmd.BindByName = true;
                        AddParameters(cmd, parms);
                        var res = cmd.ExecuteScalar();
                        return res?.ToString() ?? "0";
                    }
                }
            }
            catch (Oracle.ManagedDataAccess.Client.OracleException oex) when (oex.Message != null && oex.Message.Contains("ORA-12505"))
            {
                // try alternate connection string variant (SERVICE_NAME vs SID)
                try
                {
                    var alt = GetAlternateConnIfNeeded(OracleConn);
                    if (!string.Equals(alt, OracleConn, StringComparison.Ordinal))
                    {
                        LogDebug("ExecuteScalar: detected ORA-12505, trying alternate conn format");
                        OracleConn = alt; // switch to alternate for subsequent calls
                        using (var con = new OracleConnection(OracleConn))
                        {
                            con.Open();
                            using (var cmd = new OracleCommand(sql, con))
                            {
                                cmd.BindByName = true;
                                AddParameters(cmd, parms);
                                var res = cmd.ExecuteScalar();
                                return res?.ToString() ?? "0";
                            }
                        }
                    }
                }
                catch (Exception rex)
                {
                    LogDebug("ExecuteScalar: alternate attempt failed -> " + rex.ToString());
                }

                throw new Exception("Oracle ExecuteScalar failed: " + oex.Message, oex);
            }
            catch (Exception ex)
            {
                throw new Exception("Oracle ExecuteScalar failed: " + ex.Message, ex);
            }
        }

        private static DataTable ExecuteQuery(string sql, params (string, object)[] parms)
        {
            var dt = new DataTable();
            try
            {
                using (var con = new OracleConnection(OracleConn))
                {
                    con.Open();
                    using (var cmd = new OracleCommand(sql, con))
                    {
                        cmd.BindByName = true;
                        AddParameters(cmd, parms);
                        using (var da = new OracleDataAdapter(cmd))
                        {
                            da.Fill(dt);
                        }
                    }
                }
            }
            catch (Oracle.ManagedDataAccess.Client.OracleException oex) when (oex.Message != null && oex.Message.Contains("ORA-12505"))
            {
                try
                {
                    var alt = GetAlternateConnIfNeeded(OracleConn);
                    if (!string.Equals(alt, OracleConn, StringComparison.Ordinal))
                    {
                        LogDebug("ExecuteQuery: detected ORA-12505, trying alternate conn format");
                        OracleConn = alt;
                        using (var con = new OracleConnection(OracleConn))
                        {
                            con.Open();
                            using (var cmd = new OracleCommand(sql, con))
                            {
                                cmd.BindByName = true;
                                AddParameters(cmd, parms);
                                using (var da = new OracleDataAdapter(cmd))
                                {
                                    da.Fill(dt);
                                }
                            }
                        }
                    }
                }
                catch (Exception rex)
                {
                    LogDebug("ExecuteQuery: alternate attempt failed -> " + rex.ToString());
                }

                throw new Exception("Oracle ExecuteQuery failed: " + oex.Message, oex);
            }
            catch (Exception ex)
            {
                throw new Exception("Oracle ExecuteQuery failed: " + ex.Message, ex);
            }
            return dt;
        }

        private static int ExecuteNonQuery(string sql, params (string, object)[] parms)
        {
            try
            {
                using (var con = new OracleConnection(OracleConn))
                {
                    con.Open();
                    using (var cmd = new OracleCommand(sql, con))
                    {
                        cmd.BindByName = true;
                        AddParameters(cmd, parms);
                        return cmd.ExecuteNonQuery();
                    }
                }
            }
            catch (Oracle.ManagedDataAccess.Client.OracleException oex) when (oex.Message != null && oex.Message.Contains("ORA-12505"))
            {
                try
                {
                    var alt = GetAlternateConnIfNeeded(OracleConn);
                    if (!string.Equals(alt, OracleConn, StringComparison.Ordinal))
                    {
                        LogDebug("ExecuteNonQuery: detected ORA-12505, trying alternate conn format");
                        OracleConn = alt;
                        using (var con = new OracleConnection(OracleConn))
                        {
                            con.Open();
                            using (var cmd = new OracleCommand(sql, con))
                            {
                                cmd.BindByName = true;
                                AddParameters(cmd, parms);
                                return cmd.ExecuteNonQuery();
                            }
                        }
                    }
                }
                catch (Exception rex)
                {
                    LogDebug("ExecuteNonQuery: alternate attempt failed -> " + rex.ToString());
                }

                throw new Exception("Oracle ExecuteNonQuery failed: " + oex.Message, oex);
            }
            catch (Exception ex)
            {
                throw new Exception("Oracle ExecuteNonQuery failed: " + ex.Message, ex);
            }
        }

        private static void AddParameters(OracleCommand cmd, params (string, object)[] parms)
        {
            if (parms == null) return;
            foreach (var p in parms)
            {
                var name = p.Item1 ?? string.Empty;
                if (name.StartsWith(":")) name = name.Substring(1);
                if (name.StartsWith("@")) name = name.Substring(1);

                object val = p.Item2 ?? DBNull.Value;

                OracleParameter prm;
                if (val is DBNull)
                {
                    prm = new OracleParameter(name, DBNull.Value);
                }
                else if (val is DateTime)
                {
                    prm = new OracleParameter(name, OracleDbType.TimeStamp) { Value = val };
                }
                else if (val is int)
                {
                    prm = new OracleParameter(name, OracleDbType.Int32) { Value = val };
                }
                else if (val is long)
                {
                    prm = new OracleParameter(name, OracleDbType.Int64) { Value = val };
                }
                else if (val is decimal || val is float || val is double)
                {
                    prm = new OracleParameter(name, OracleDbType.Decimal) { Value = val };
                }
                else
                {
                    prm = new OracleParameter(name, val);
                }

                cmd.Parameters.Add(prm);
            }
        }
