        public static List<Drink> LoadDrinks()
        {
            EnsureOracleConfigured();
            try
            {
                EnsureOracleTables();
                var dt = ExecuteQuery("SELECT ID, NAME, CATEGORY, PRICE, STOCK FROM DRINKS");
                var list = new List<Drink>();
                foreach (DataRow r in dt.Rows)
                {
                    list.Add(new Drink
                    {
                        Id = r["ID"].ToString(),
                        Name = r["NAME"].ToString(),
                        Category = r["CATEGORY"].ToString(),
                        Price = decimal.TryParse(r["PRICE"].ToString(), out var p) ? p : 0,
                        Stock = int.TryParse(r["STOCK"].ToString(), out var s) ? s : 0
                    });
                }

                if (list.Count > 0) return list;

                // if empty, insert defaults and return them
                var defaults = GetDefaultDrinks();
                SaveDrinks(defaults);
                return defaults;
            }
            catch (Exception ex)
            {
                LogDebug("LoadDrinks: Oracle error -> " + ex.ToString());
                throw;
            }
        }

        public static void SaveDrinks(List<Drink> drinks)
        {
            EnsureOracleConfigured();
            try
            {
                EnsureOracleTables();
                using (var con = new OracleConnection(OracleConn))
                {
                    con.Open();
                    using (var tx = con.BeginTransaction())
                    using (var cmd = con.CreateCommand())
                    {
                        cmd.Transaction = tx;
                        cmd.BindByName = true;

                        // Upsert each drink: update if exists, otherwise insert
                        cmd.CommandText = "UPDATE DRINKS SET NAME = :name, CATEGORY = :cat, PRICE = :price, STOCK = :stock WHERE ID = :id";
                        foreach (var d in drinks)
                        {
                            cmd.Parameters.Clear();
                            cmd.Parameters.Add(new OracleParameter("id", OracleDbType.Varchar2) { Value = d.Id });
                            cmd.Parameters.Add(new OracleParameter("name", OracleDbType.Varchar2) { Value = d.Name ?? string.Empty });
                            cmd.Parameters.Add(new OracleParameter("cat", OracleDbType.Varchar2) { Value = d.Category ?? string.Empty });
                            cmd.Parameters.Add(new OracleParameter("price", OracleDbType.Decimal) { Value = d.Price });
                            cmd.Parameters.Add(new OracleParameter("stock", OracleDbType.Int32) { Value = d.Stock });

                            var rows = cmd.ExecuteNonQuery();
                            if (rows == 0)
                            {
                                cmd.Parameters.Clear();
                                cmd.CommandText = "INSERT INTO DRINKS (ID, NAME, CATEGORY, PRICE, STOCK) VALUES (:id, :name, :cat, :price, :stock)";
                                cmd.Parameters.Add(new OracleParameter("id", OracleDbType.Varchar2) { Value = d.Id });
                                cmd.Parameters.Add(new OracleParameter("name", OracleDbType.Varchar2) { Value = d.Name ?? string.Empty });
                                cmd.Parameters.Add(new OracleParameter("cat", OracleDbType.Varchar2) { Value = d.Category ?? string.Empty });
                                cmd.Parameters.Add(new OracleParameter("price", OracleDbType.Decimal) { Value = d.Price });
                                cmd.Parameters.Add(new OracleParameter("stock", OracleDbType.Int32) { Value = d.Stock });
                                cmd.ExecuteNonQuery();

                                // restore update command text for next iteration
                                cmd.CommandText = "UPDATE DRINKS SET NAME = :name, CATEGORY = :cat, PRICE = :price, STOCK = :stock WHERE ID = :id";
                            }
                        }

                        tx.Commit();
                    }
                }
            }
            catch (Exception ex)
            {
                LogDebug("SaveDrinks: Oracle error -> " + ex.ToString());
                throw;
            }
        }
